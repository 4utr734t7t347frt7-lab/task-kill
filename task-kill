#!/bin/bash

set -e

FORCE=false
DRYRUN=false

# -------------------------
# Ctrl+C handler (abort anytime)
# -------------------------
abort() {
    echo ""
    echo "❌ Aborted by user (Ctrl+C). No processes were killed."
    exit 1
}

trap abort SIGINT

# -------------------------
# Fun exit messages
# -------------------------
quotes=(
    "💀 That process has left the server... like Skyrim guards' free time."
    "🎬 Game over. Insert coin to respawn."
    "⚔️ The target has been eliminated. Mission accomplished, Solid Snake."
    "🧙‍♂️ You shall not pass... anymore (Gandalf approved termination)."
    "🚀 Houston, we have no process."
    "🧠 System says: 'I’ll be back.' — not this time, Terminator."
    "🎮 Respawn denied. Git gud, process."
    "🕶️ Process terminated. Welcome to the Matrix."
    "🔥 It’s over 9000... processes remaining: less."
    "☠️ Another one bites the dust... Queen would approve."
)

random_quote() {
    echo ""
    echo "${quotes[$RANDOM % ${#quotes[@]}]}"
}

# -------------------------
# Flags
# -------------------------
while [[ "$1" != "" ]]; do
    case $1 in
        -f|--force)
            FORCE=true
            ;;
        -n|--dry-run)
            DRYRUN=true
            ;;
        -h|--help)
            echo "Usage: $0 [-f|--force] [-n|--dry-run]"
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
    shift
done

# -------------------------
# Header
# -------------------------
echo "=========================="
echo "       TASK-KILL v2"
echo "=========================="
echo ""

# -------------------------
# Pre-input cancel option
# -------------------------
echo "[ENTER] Continue"
echo "[c] Cancel"
read -r prechoice

if [[ "$prechoice" =~ ^[cC]$ ]]; then
    echo "❌ Cancelled before input. No action taken."
    exit 0
fi

echo ""

# -------------------------
# Input
# -------------------------
read -p "Enter process name: " task

if [ -z "$task" ]; then
    echo "No process entered."
    exit 1
fi

# Prevent self-kill
if [[ "$task" == "task-kill" ]]; then
    echo "😄 Nice try. You can’t kill this tool with itself."
    exit 1
fi

echo ""
echo "Matching processes:"
pgrep -fl "$task" || { echo "No processes found."; exit 0; }

# -------------------------
# PID selection
# -------------------------
if command -v fzf >/dev/null 2>&1; then
    echo ""
    echo "Select PID or type 'all' to kill everything:"
    pid=$( (pgrep -f "$task"; echo "all") | fzf ) || exit 0
else
    read -p "Enter PID to kill or type 'all': " pid
fi

# -------------------------
# Dry run
# -------------------------
if $DRYRUN; then
    echo ""
    echo "[DRY RUN]"
    if [ "$pid" = "all" ] || [ -z "$pid" ]; then
        echo "Would kill ALL processes matching: $task"
    else
        echo "Would kill PID: $pid"
    fi
    exit 0
fi

# -------------------------
# Final confirmation
# -------------------------
echo ""
read -p "⚠️ Are you sure? (y/N): " confirm
confirm=${confirm,,}

if [[ "$confirm" != "y" ]]; then
    echo "Cancelled."
    exit 0
fi

# -------------------------
# Kill logic
# -------------------------
echo ""

if [ "$pid" = "all" ] || [ -z "$pid" ]; then
    echo "Killing ALL processes matching: $task"

    if $FORCE; then
        pkill -9 -f "$task"
        echo "Force-killed all matches."
    else
        pkill -15 -f "$task"
        sleep 1
        pkill -9 -f "$task" 2>/dev/null || true
        echo "Gracefully terminated (then forced if needed)."
    fi
else
    echo "Killing PID: $pid"
    kill "$pid" 2>/dev/null || kill -9 "$pid"
fi

echo "Done."

# -------------------------
# Fun ending quote
# -------------------------
random_quote
